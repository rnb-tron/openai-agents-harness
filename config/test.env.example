ENVTYPE=test                         # 环境类型；会加载 config/test.env
APP_NAME=openai-agent-sdk            # 应用名称
APP_VERSION=0.1.0                    # 应用版本号
APP_PROFILE=test                     # 应用运行画像；测试环境使用 test
DEBUG=true                           # 是否开启调试模式
HOST=0.0.0.0                         # 服务监听地址
PORT=8080                            # 服务监听端口
LOG_LEVEL=INFO                       # 日志级别

HTTP_CLIENT_ENABLED=true             # 是否启用共享 HTTP 客户端
HTTP_TIMEOUT_SECONDS=30              # HTTP 请求总超时时间，单位秒
HTTP_CONNECT_TIMEOUT_SECONDS=10      # HTTP 建连超时时间，单位秒
HTTP_READ_TIMEOUT_SECONDS=20         # HTTP 读取超时时间，单位秒
HTTP_WRITE_TIMEOUT_SECONDS=10        # HTTP 写入超时时间，单位秒
HTTP_MAX_CONNECTIONS=100             # HTTP 客户端最大连接数
HTTP_MAX_KEEPALIVE_CONNECTIONS=20    # HTTP 客户端最大空闲长连接数
HTTP_KEEPALIVE_EXPIRY_SECONDS=30     # HTTP 空闲长连接保留时间，单位秒
HTTP_FOLLOW_REDIRECTS=true           # HTTP 客户端是否自动跟随重定向
HTTP_VERIFY_TLS=true                 # HTTP 客户端是否校验 TLS 证书
REDIS_ENABLED=false                  # 是否启用 Redis 资源
KAFKA_ENABLED=false                  # 是否启用 Kafka 资源
DATABASE_ENABLED=false               # 是否启用数据库资源

REDIS_URL=redis://localhost:6379/0   # Redis 主节点连接地址
REDIS_SLAVE_URL=                     # Redis 从节点连接地址；为空表示不使用
KAFKA_BOOTSTRAP_SERVERS=localhost:9092 # Kafka 初始连接服务地址
KAFKA_TOPIC=agent_events             # Kafka 默认事件主题
# 本地 Docker 示例：
# DATABASE_URL=mysql+aiomysql://agent:agent_pass@127.0.0.1:13306/agent_harness
DATABASE_URL=                        # 数据库连接地址；数据库能力启用时必填
DATABASE_POOL_SIZE=10                # 数据库连接池基础连接数
DATABASE_MAX_OVERFLOW=20             # 数据库连接池最大溢出连接数
DATABASE_POOL_TIMEOUT_SECONDS=30     # 数据库连接池获取连接超时时间，单位秒
DATABASE_POOL_RECYCLE_SECONDS=1800   # 数据库连接回收时间，单位秒
DATABASE_POOL_PRE_PING=true          # 获取数据库连接前是否做健康探测

# 会话存储配置；推荐使用 MySQL，保存会话和完整消息流水
SESSION_STORE_ENABLED=false          # 是否启用会话存储
SESSION_STORE_AUTO_CREATE=true       # 是否在启动时自动创建会话存储表

OPENAI_API_KEY=                      # OpenAI 或兼容服务 API Key
OPENAI_BASE_URL=                     # OpenAI 兼容服务 Base URL；为空使用默认地址
AGENT_MODEL_DEFAULT=gpt-4o-mini      # Agent 默认模型
AGENT_MODEL_REASONING=gpt-4.1-mini   # Agent 推理任务模型

# 人工审批配置；基于 OpenAI Agents SDK 原生工具审批
HITL_ENABLED=false                   # 是否启用人工审批
HITL_APPROVAL_TIMEOUT=300            # 人工审批超时时间，单位秒
HITL_REQUIRE_APPROVAL_TOOLS=         # 需要人工审批的工具名，CSV 格式，例如 delete_data,send_notification
HITL_AUTO_APPROVE_TOOLS=             # 自动审批通过的工具名，CSV 格式

# 执行检查点配置；进程内运行快照，不等同于 SDK RunState 持久化
CHECKPOINT_ENABLED=false             # 是否启用执行检查点
CHECKPOINT_MAX_CHECKPOINTS=10        # 每个会话最多保留的检查点数量
CHECKPOINT_AUTO_SAVE=true            # 是否在运行前后自动保存检查点

# Agent 协作配置；基于 OpenAI Agents SDK 原生 Handoff
HANDOFF_ENABLED=false                # 是否启用 Handoff
# JSON 对象；每个目标 Agent 支持 description、instructions，可选 enabled=false
HANDOFF_AGENTS_JSON=                 # Handoff 目标 Agent 配置 JSON

# 协议层认证配置；JWT
AUTH_ENABLED=false                   # 是否启用认证插件
AUTH_STRICT=false                    # true 表示缺少 token 返回 401；false 表示缺少 token 视为匿名用户
AUTH_JWT_ALGORITHM=HS256             # JWT 签名算法，支持 HS256 / RS256
AUTH_JWT_SECRET=                     # HS256 算法所需密钥
AUTH_JWT_PUBLIC_KEY=                 # RS256 算法所需公钥，PEM 格式
AUTH_JWT_ISSUER=                     # JWT issuer 校验值；为空不校验
AUTH_JWT_AUDIENCE=                   # JWT audience 校验值；为空不校验
AUTH_JWT_LEEWAY_SEC=30               # JWT 时间类字段校验宽限秒数
AUTH_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui # 跳过认证的路径，CSV 格式

# 协议层限流配置；Token Bucket，用户维度限流依赖 Auth
RATE_LIMIT_ENABLED=false             # 是否启用限流插件
RATE_LIMIT_BACKEND=redis             # 限流后端，支持 redis / memory
RATE_LIMIT_DEFAULT_LIMIT=60          # 默认窗口内允许请求数
RATE_LIMIT_DEFAULT_WINDOW_SEC=60     # 默认限流窗口时长，单位秒
RATE_LIMIT_DEFAULT_BURST=10          # 默认突发请求额度
RATE_LIMIT_KEY_STRATEGY=principal    # 限流键策略；principal 为用户维度，principal_or_ip/ip 为兼容替代
RATE_LIMIT_FAIL_OPEN=false           # false 表示限流后端故障时返回 503；true 表示放行
# 按路由覆盖限流配置，JSON 格式；例如 {"/chat":{"limit":5,"window_sec":60,"burst":1}}
RATE_LIMIT_ROUTES=                   # 路由级限流覆盖配置 JSON
RATE_LIMIT_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui # 跳过限流的路径，CSV 格式

# 记忆系统配置
MEMORY_ENABLED=false                 # 是否启用长期记忆能力
MEMORY_SHORT_TERM_TTL=3600           # 短期记忆缓存 TTL，单位秒
MEMORY_MEM0_MODE=local               # Mem0 模式，支持 local / platform
MEMORY_MEM0_API_KEY=                 # Mem0 platform 模式所需 API Key
MEMORY_MEM0_CONFIG_JSON=             # 可选的 Mem0 OSS 配置 JSON
MEMORY_VECTOR_STORE=none             # 向量存储后端，支持 none / pgvector / elasticsearch
MEMORY_PGVECTOR_DATABASE_URL=        # pgvector 数据库地址，例如 postgresql://agent:agent_pass@127.0.0.1:15432/agent_memory
MEMORY_PGVECTOR_TABLE=agent_memories # pgvector 记忆表名
MEMORY_ES_HOSTS=http://localhost:9200 # Elasticsearch 地址
MEMORY_ES_INDEX=agent_memories       # Elasticsearch 记忆索引名
MEMORY_PREFERENCE_CACHE_TTL_SEC=900  # 用户偏好缓存 TTL，单位秒
MEMORY_EMBEDDING_MODEL=text-embedding-3-small # 记忆向量化模型
MEMORY_VECTOR_DIMENSION=1536         # 记忆向量维度
MEMORY_MAX_CONTEXT_TURNS=6           # 注入短期上下文的最大轮数
MEMORY_RETRIEVAL_TOP_K=3             # 长期记忆召回数量
MEMORY_IMPORTANCE_THRESHOLD=0.3      # 记忆重要性阈值
MEMORY_FORGETTING_ENABLED=true       # 是否启用记忆遗忘机制
MEMORY_SESSION_SUMMARY_ENABLED=false # 是否启用会话摘要
MEMORY_SESSION_SUMMARY_CACHE_TTL=2592000 # 会话摘要缓存 TTL，单位秒
MEMORY_SESSION_SUMMARY_INITIAL_MESSAGES=2 # 首次生成摘要所需消息数
MEMORY_SESSION_SUMMARY_UPDATE_MESSAGES=4 # 后续更新摘要所需新增消息数
MEMORY_SESSION_SUMMARY_MODEL=        # 会话摘要模型；为空复用 AGENT_MODEL_DEFAULT
MEMORY_SESSION_SUMMARY_MAX_TOKENS=512 # 会话摘要最大输出 token 数
MEMORY_SESSION_SUMMARY_MAX_SOURCE_MESSAGES=20 # 生成摘要时最多读取的源消息数

# 上下文压缩能力配置
COMPRESSION_ENABLED=false            # 是否启用上下文压缩
COMPRESSION_STRATEGY=token_budget    # 压缩策略，支持 token_budget / rolling_summary / hybrid
COMPRESSION_SAFETY_RATIO=0.9         # 输入预算安全系数，计算方式为 (上下文窗口 - 预留输出) * 系数
COMPRESSION_KEEP_RECENT_TURNS=4      # rolling_summary 策略保留最近 K 轮原文
COMPRESSION_SUMMARY_MODEL=           # 压缩摘要模型；为空复用 AGENT_MODEL_DEFAULT
COMPRESSION_SUMMARY_MAX_TOKENS=512   # 单次压缩摘要最大输出 token 数
COMPRESSION_CACHE_TTL_SEC=3600       # 压缩摘要缓存 TTL；0 表示禁用缓存
COMPRESSION_FAIL_OPEN=true           # true 表示压缩失败时放行原上下文；false 表示抛出异常

# Prompt 管理能力配置
PROMPT_ENABLED=false                 # 是否启用 Prompt 管理
PROMPT_BACKEND=composite             # Prompt 后端，composite 表示 Langfuse + 本地 YAML 降级，也支持 langfuse / yaml
PROMPT_LOCAL_DIR=prompts             # 本地 YAML Prompt 目录，相对项目根目录
PROMPT_DEFAULT_LABEL=prod            # Langfuse get_prompt 使用的默认 label
PROMPT_CACHE_TTL_SEC=300             # Prompt 进程内 LRU 缓存 TTL，单位秒
PROMPT_WARMUP_NAMES=                 # 启动时预热的 Prompt 名称，CSV 格式，例如 agents.main_chat,capabilities.summary
PROMPT_FAIL_OPEN=true                # true 表示 Prompt 获取失败时降级到硬编码内容；false 表示抛出异常

# 可观测性系统配置；Langfuse
LANGFUSE_ENABLED=false               # 是否启用 Langfuse 可观测性
LANGFUSE_PUBLIC_KEY=                 # Langfuse 公钥
LANGFUSE_SECRET_KEY=                 # Langfuse 密钥
LANGFUSE_BASE_URL=http://agent-otel-test.ke.com # Langfuse 服务地址
LANGFUSE_TRACING_ENABLED=true        # 是否启用链路追踪
LANGFUSE_METRICS_ENABLED=true        # 是否启用指标采集
LANGFUSE_BATCH_SIZE=100              # Langfuse 批量上报条数
LANGFUSE_FLUSH_INTERVAL=5.0          # Langfuse 刷新间隔，单位秒
LANGFUSE_SAMPLING_RATE=1.0           # Langfuse 采样率
LANGFUSE_MASK_PII=true               # 是否对可观测数据中的敏感信息脱敏
LANGFUSE_REQUEST_TIMEOUT=30          # Langfuse 请求超时时间，单位秒
LANGFUSE_MAX_RETRIES=3               # Langfuse 请求最大重试次数
LANGFUSE_RETRY_DELAY=1.0             # Langfuse 请求重试间隔，单位秒
