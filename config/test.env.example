ENVTYPE=test
APP_NAME=openai-agent-sdk
APP_PROFILE=test
DEBUG=true
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

HTTP_CLIENT_ENABLED=true
HTTP_TIMEOUT_SECONDS=30
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_READ_TIMEOUT_SECONDS=20
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_KEEPALIVE_EXPIRY_SECONDS=30
HTTP_FOLLOW_REDIRECTS=true
HTTP_VERIFY_TLS=true
REDIS_ENABLED=false
KAFKA_ENABLED=false
DATABASE_ENABLED=false

REDIS_URL=redis://localhost:6379/0
REDIS_SLAVE_URL=
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=agent_events
# Local Docker example:
# DATABASE_URL=mysql+aiomysql://agent:agent_pass@127.0.0.1:13306/agent_harness
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true

# Session Store (MySQL recommended, stores sessions and full message transcripts)
SESSION_STORE_ENABLED=false
SESSION_STORE_AUTO_CREATE=true

OPENAI_API_KEY=
OPENAI_BASE_URL=
AGENT_MODEL_DEFAULT=gpt-4o-mini
AGENT_MODEL_REASONING=gpt-4.1-mini

# Human-in-the-Loop (OpenAI Agents SDK native approval)
HITL_ENABLED=false
HITL_APPROVAL_TIMEOUT=300
HITL_REQUIRE_APPROVAL_TOOLS=            # CSV, e.g. "delete_data,send_notification"
HITL_AUTO_APPROVE_TOOLS=                # CSV

# Execution Checkpoint (in-process run snapshots, not SDK RunState persistence)
CHECKPOINT_ENABLED=false
CHECKPOINT_MAX_CHECKPOINTS=10
CHECKPOINT_AUTO_SAVE=true

# OpenAI Agents SDK native Handoff
HANDOFF_ENABLED=false
# JSON object; each target supports description, instructions and optional enabled=false
HANDOFF_AGENTS_JSON=

# Protocol-layer Auth (JWT)
AUTH_ENABLED=false
AUTH_STRICT=false                 # true=missing token -> 401; false=missing token -> anonymous
AUTH_JWT_ALGORITHM=HS256          # HS256 / RS256
AUTH_JWT_SECRET=                  # required for HS256
AUTH_JWT_PUBLIC_KEY=               # required for RS256 (PEM)
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_LEEWAY_SEC=30
AUTH_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui

# Protocol-layer Rate Limit (token bucket; user-dimensional mode requires Auth)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=redis          # redis / memory
RATE_LIMIT_DEFAULT_LIMIT=60
RATE_LIMIT_DEFAULT_WINDOW_SEC=60
RATE_LIMIT_DEFAULT_BURST=10
RATE_LIMIT_KEY_STRATEGY=principal         # user-dimensional; principal_or_ip/ip are explicit alternatives
RATE_LIMIT_FAIL_OPEN=false                # false=backend failure returns 503
# Per-route overrides as JSON. Example: {"/chat":{"limit":5,"window_sec":60,"burst":1}}
RATE_LIMIT_ROUTES=
RATE_LIMIT_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui

# Memory System Configuration
MEMORY_ENABLED=false
MEMORY_SHORT_TERM_TTL=3600
MEMORY_MEM0_MODE=local                # local / platform
MEMORY_MEM0_API_KEY=                  # required only for platform mode
MEMORY_MEM0_CONFIG_JSON=              # optional Mem0 OSS config JSON
MEMORY_VECTOR_STORE=none              # none / pgvector / elasticsearch
MEMORY_PGVECTOR_DATABASE_URL=         # e.g. postgresql://agent:agent_pass@127.0.0.1:15432/agent_memory
MEMORY_PGVECTOR_TABLE=agent_memories
MEMORY_ES_HOSTS=http://localhost:9200
MEMORY_ES_INDEX=agent_memories
MEMORY_PREFERENCE_CACHE_TTL_SEC=900
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_VECTOR_DIMENSION=1536
MEMORY_MAX_CONTEXT_TURNS=6
MEMORY_RETRIEVAL_TOP_K=3
MEMORY_IMPORTANCE_THRESHOLD=0.3
MEMORY_FORGETTING_ENABLED=true
MEMORY_SESSION_SUMMARY_ENABLED=false
MEMORY_SESSION_SUMMARY_CACHE_TTL=2592000
MEMORY_SESSION_SUMMARY_INITIAL_MESSAGES=4
MEMORY_SESSION_SUMMARY_UPDATE_MESSAGES=6
MEMORY_SESSION_SUMMARY_MODEL=          # empty -> reuse AGENT_MODEL_DEFAULT
MEMORY_SESSION_SUMMARY_MAX_TOKENS=512

# Context Compression Capability
COMPRESSION_ENABLED=false
COMPRESSION_STRATEGY=token_budget        # token_budget / rolling_summary / hybrid
COMPRESSION_SAFETY_RATIO=0.9             # input budget = (window - reserved_for_output) * ratio
COMPRESSION_KEEP_RECENT_TURNS=4          # rolling_summary: keep last K turns verbatim
COMPRESSION_SUMMARY_MODEL=               # empty -> reuse AGENT_MODEL_DEFAULT
COMPRESSION_SUMMARY_MAX_TOKENS=512       # per-summary output cap
COMPRESSION_CACHE_TTL_SEC=3600           # 0 to disable summary caching
COMPRESSION_FAIL_OPEN=true               # false -> compression failure raises

# Prompt Management Capability
PROMPT_ENABLED=false
PROMPT_BACKEND=composite                 # composite (Langfuse + yaml fallback) / langfuse / yaml
PROMPT_LOCAL_DIR=prompts                 # base dir for LocalYamlStore (relative to project root)
PROMPT_DEFAULT_LABEL=prod                # Langfuse label for get_prompt
PROMPT_CACHE_TTL_SEC=300                 # in-process LRU TTL
PROMPT_WARMUP_NAMES=                     # CSV of prompt names to warm at startup, e.g. "agents.main_chat,capabilities.summary"
PROMPT_FAIL_OPEN=true                    # false -> prompt fetch failure raises (instead of falling back to hardcoded string)

# Observability System (Langfuse)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://agent-otel-test.ke.com
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_METRICS_ENABLED=true
LANGFUSE_SAMPLING_RATE=1.0
LANGFUSE_MASK_PII=true
