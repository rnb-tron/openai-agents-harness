# 应用基础配置
ENVTYPE=prod                        # 环境类型；启动时加载 config/prod.env
APP_NAME=openai-agents-harness      # 应用名称
APP_VERSION=0.1.0                   # 应用版本号
APP_PROFILE=production              # 应用运行画像
DEBUG=false                         # 是否开启调试模式
HOST=0.0.0.0                        # 服务监听地址
PORT=8080                           # 服务监听端口
LOG_LEVEL=INFO                      # 日志级别
MATRIX_APPLOGS_DIR=data/logs        # 应用日志输出目录

# 通用 HTTP 客户端配置
HTTP_TIMEOUT_SECONDS=30             # HTTP 请求总超时时间，单位秒
HTTP_CONNECT_TIMEOUT_SECONDS=10     # HTTP 建连超时时间，单位秒
HTTP_READ_TIMEOUT_SECONDS=20        # HTTP 读取超时时间，单位秒
HTTP_WRITE_TIMEOUT_SECONDS=10       # HTTP 写入超时时间，单位秒
HTTP_MAX_CONNECTIONS=200            # HTTP 客户端最大连接数
HTTP_MAX_KEEPALIVE_CONNECTIONS=50   # HTTP 客户端最大空闲长连接数
HTTP_KEEPALIVE_EXPIRY_SECONDS=30    # HTTP 空闲长连接保留时间，单位秒
HTTP_FOLLOW_REDIRECTS=true          # HTTP 客户端是否自动跟随重定向
HTTP_VERIFY_TLS=true                # HTTP 客户端是否校验 TLS 证书

# Redis 资源配置
REDIS_ENABLED=true                  # 是否启用 Redis 资源
REDIS_URL=redis://:CHANGE_ME@redis.example.com:6379/0 # Redis 主节点连接地址
REDIS_SLAVE_URL="" # Redis 从节点连接地址；为空表示不使用

# 会话存储配置
SESSION_STORE_ENABLED=true          # 是否启用会话存储
SESSION_STORE_AUTO_CREATE=false     # 是否在启动时自动创建会话存储表

# 会话存储数据库配置
SESSION_STORE_DATABASE_SCHEME=mysql+aiomysql      # SQLAlchemy 数据库驱动协议；MySQL 使用 mysql+aiomysql，PostgreSQL 使用 postgresql+asyncpg
SESSION_STORE_DATABASE_HOST=mysql.example.com     # 数据库主机
SESSION_STORE_DATABASE_PORT=3306                  # 数据库端口
SESSION_STORE_DATABASE_NAME=agent_harness         # 数据库名称
SESSION_STORE_DATABASE_USER=agent                 # 数据库用户名
SESSION_STORE_DATABASE_PASSWORD=CHANGE_ME         # 数据库密码，可直接写原始特殊字符
SESSION_STORE_DATABASE_SSLMODE="" # 数据库 sslmode；PostgreSQL 需要时填写
SESSION_STORE_DATABASE_POOL_SIZE=20               # 数据库连接池基础连接数
SESSION_STORE_DATABASE_MAX_OVERFLOW=40            # 数据库连接池最大溢出连接数
SESSION_STORE_DATABASE_POOL_TIMEOUT_SECONDS=30    # 数据库连接池获取连接超时时间，单位秒
SESSION_STORE_DATABASE_POOL_RECYCLE_SECONDS=1800  # 数据库连接回收时间，单位秒
SESSION_STORE_DATABASE_POOL_PRE_PING=true         # 获取数据库连接前是否做健康探测

# 模型访问配置
OPENAI_API_KEY=CHANGE_ME            # OpenAI 或兼容服务 API Key
OPENAI_BASE_URL="" # OpenAI 兼容服务 Base URL；为空使用默认地址
AGENT_MODEL_DEFAULT=gpt-4o-mini     # Agent 默认模型
AGENT_MODEL_REASONING=gpt-4.1-mini  # Agent 推理任务模型

# 模型弹性配置
MODEL_RESILIENCE_ENABLED=false      # 是否启用模型弹性包装
MODEL_FALLBACK_ENABLED=false        # 是否启用模型降级
MODEL_FALLBACK_CHAIN="" # 降级模型链，CSV 格式
MODEL_RETRY_ENABLED=false           # 是否启用模型调用重试
MODEL_MAX_RETRIES=2                 # 最大重试次数
MODEL_RETRY_DELAY=1.0               # 初始重试间隔，单位秒
MODEL_RETRY_MAX_DELAY=10.0          # 最大重试间隔，单位秒
MODEL_TIMEOUT_ENABLED=false         # 是否启用模型调用超时控制
MODEL_TOTAL_TIMEOUT=30.0            # 总超时时间，单位秒
MODEL_PER_REQUEST_TIMEOUT=10.0      # 单次请求超时时间，单位秒

# 推理摘要配置
REASONING_SUMMARY_ENABLED=false     # 是否请求模型返回推理摘要
REASONING_SUMMARY_MODE=auto         # 推理摘要模式，支持 auto / concise / detailed

# 人工审批配置
HITL_ENABLED=false                  # 是否启用人工审批
HITL_APPROVAL_TIMEOUT=300           # 人工审批超时时间，单位秒
HITL_REQUIRE_APPROVAL_TOOLS="" # 需要人工审批的工具名，CSV 格式
HITL_AUTO_APPROVE_TOOLS="" # 自动审批通过的工具名，CSV 格式

# 执行检查点配置
CHECKPOINT_ENABLED=false            # 是否启用执行检查点
CHECKPOINT_MAX_CHECKPOINTS=10       # 每个会话最多保留的检查点数量
CHECKPOINT_AUTO_SAVE=true           # 是否在运行前后自动保存检查点

# Agent 协作配置
HANDOFF_ENABLED=false               # 是否启用 Handoff
HANDOFF_AGENTS_JSON="" # Handoff 目标 Agent 配置 JSON

# 协议层认证配置
AUTH_ENABLED=true                   # 是否启用认证插件
AUTH_STRICT=true                    # 是否要求所有非跳过路径必须携带 token
AUTH_JWT_ALGORITHM=HS256            # JWT 签名算法，支持 HS256 / RS256
AUTH_JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES # HS256 算法所需密钥
AUTH_JWT_PUBLIC_KEY="" # RS256 算法所需公钥，PEM 格式
AUTH_JWT_ISSUER="" # JWT issuer 校验值；为空不校验
AUTH_JWT_AUDIENCE="" # JWT audience 校验值；为空不校验
AUTH_JWT_LEEWAY_SEC=30              # JWT 时间类字段校验宽限秒数
AUTH_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui # 跳过认证的路径，CSV 格式

# 协议层限流配置
RATE_LIMIT_ENABLED=true             # 是否启用限流插件
RATE_LIMIT_BACKEND=redis            # 限流后端，支持 redis / memory
RATE_LIMIT_DEFAULT_LIMIT=120        # 默认窗口内允许请求数
RATE_LIMIT_DEFAULT_WINDOW_SEC=60    # 默认限流窗口时长，单位秒
RATE_LIMIT_DEFAULT_BURST=20         # 默认突发请求额度
RATE_LIMIT_KEY_STRATEGY=principal   # 限流键策略，支持 principal / principal_or_ip / ip
RATE_LIMIT_FAIL_OPEN=false          # 限流后端故障时是否放行
RATE_LIMIT_ROUTES="" # 路由级限流覆盖配置 JSON
RATE_LIMIT_SKIP_PATHS=/health,/docs,/redoc,/openapi.json,/ui # 跳过限流的路径，CSV 格式

# 短期记忆配置
MEMORY_SHORT_TERM_ENABLED=true      # 是否启用短期会话记忆上下文
MEMORY_SHORT_TERM_TTL=3600          # 短期记忆缓存 TTL，单位秒
MEMORY_SHORT_TERM_CONTEXT_MAX_TURNS=6 # 短期记忆注入上下文的最大轮数

# 会话摘要配置
MEMORY_SESSION_SUMMARY_ENABLED=true # 是否启用会话摘要
MEMORY_SESSION_SUMMARY_CACHE_TTL=2592000 # 会话摘要缓存 TTL，单位秒
MEMORY_SESSION_SUMMARY_INITIAL_MESSAGES=4 # 首次生成摘要所需消息数
MEMORY_SESSION_SUMMARY_UPDATE_MESSAGES=6 # 后续更新摘要所需新增消息数
MEMORY_SESSION_SUMMARY_MODEL="" # 会话摘要模型；为空复用 AGENT_MODEL_DEFAULT
MEMORY_SESSION_SUMMARY_MAX_TOKENS=512 # 会话摘要最大输出 token 数
MEMORY_SESSION_SUMMARY_MAX_SOURCE_MESSAGES=20 # 生成摘要时最多读取的源消息数

# 长期记忆配置
MEMORY_LONG_TERM_ENABLED=true       # 是否启用长期记忆
MEMORY_LONG_TERM_PROVIDER=mem0      # 长期记忆管理框架，目前支持 mem0
MEMORY_LONG_TERM_MEM0_MODE=local    # Mem0 模式，支持 local / platform
MEMORY_LONG_TERM_MEM0_API_KEY="" # Mem0 platform 模式所需 API Key
MEMORY_LONG_TERM_MEM0_CONFIG_JSON="" # 可选的 Mem0 OSS 配置 JSON
MEMORY_LONG_TERM_VECTOR_STORE=pgvector # 长期记忆向量存储后端，支持 none / pgvector / elasticsearch
MEMORY_LONG_TERM_CONTEXT_MAX_MEMORIES=3 # 长期记忆注入上下文的最大条数
MEMORY_PREFERENCE_CACHE_TTL_SEC=900 # 用户偏好缓存 TTL，单位秒
MEMORY_EMBEDDING_MODEL=text-embedding-3-small # 记忆向量化模型
MEMORY_VECTOR_DIMENSION=1536        # 记忆向量维度

# pgvector 向量存储配置
MEMORY_PGVECTOR_PGHOST=pgvector.example.com # pgvector PostgreSQL 主机
MEMORY_PGVECTOR_PGPORT=5432         # pgvector PostgreSQL 端口
MEMORY_PGVECTOR_PGDATABASE=agent_memory # pgvector PostgreSQL 数据库名
MEMORY_PGVECTOR_PGUSER=agent        # pgvector PostgreSQL 用户名
MEMORY_PGVECTOR_PGPASSWORD=CHANGE_ME # pgvector PostgreSQL 密码，可直接写原始特殊字符
MEMORY_PGVECTOR_PGSSLMODE="" # pgvector PostgreSQL sslmode；为空表示默认
MEMORY_PGVECTOR_TABLE=agent_memories # pgvector 记忆表名

# Elasticsearch 向量存储配置
MEMORY_ES_HOSTS="" # Elasticsearch 地址，多个地址使用逗号分隔
MEMORY_ES_INDEX=agent_memories      # Elasticsearch 记忆索引名

# 上下文压缩配置
COMPRESSION_ENABLED=true            # 是否启用上下文压缩
COMPRESSION_STRATEGY=token_budget   # 压缩策略，支持 token_budget / rolling_summary / hybrid
COMPRESSION_SAFETY_RATIO=0.9        # 输入预算安全系数
COMPRESSION_KEEP_RECENT_TURNS=4     # rolling_summary 策略保留最近 K 轮原文
COMPRESSION_SUMMARY_MODEL="" # 压缩摘要模型；为空复用 AGENT_MODEL_DEFAULT
COMPRESSION_SUMMARY_MAX_TOKENS=512  # 单次压缩摘要最大输出 token 数
COMPRESSION_CACHE_TTL_SEC=3600      # 压缩摘要缓存 TTL；0 表示禁用缓存
COMPRESSION_FAIL_OPEN=true          # 压缩失败时是否放行原上下文

# Prompt 管理配置
PROMPT_ENABLED=true                 # 是否启用 Prompt 管理
PROMPT_BACKEND=composite            # Prompt 后端，支持 composite / langfuse / yaml
PROMPT_LOCAL_DIR=prompts            # 本地 YAML Prompt 目录
PROMPT_DEFAULT_LABEL=prod           # Langfuse Prompt 默认 label
PROMPT_CACHE_TTL_SEC=300            # Prompt 进程内缓存 TTL，单位秒
PROMPT_WARMUP_NAMES=agents.main_chat,capabilities.summary # 启动时预热的 Prompt 名称，CSV 格式
PROMPT_FAIL_OPEN=true               # Prompt 获取失败时是否降级到默认内容

# 可观测性配置
LANGFUSE_ENABLED=true               # 是否启用 Langfuse 可观测性
LANGFUSE_PUBLIC_KEY=CHANGE_ME       # Langfuse 公钥
LANGFUSE_SECRET_KEY=CHANGE_ME       # Langfuse 密钥
LANGFUSE_BASE_URL=https://langfuse.example.com # Langfuse 服务地址
LANGFUSE_OTEL_TRACES_EXPORT_PATH="" # Langfuse OTEL trace 导出路径；为空使用默认路径
LANGFUSE_TRACING_ENABLED=true       # 是否启用链路追踪
LANGFUSE_METRICS_ENABLED=true       # 是否启用指标采集
LANGFUSE_BATCH_SIZE=100             # Langfuse 批量上报条数
LANGFUSE_FLUSH_INTERVAL=5.0         # Langfuse 刷新间隔，单位秒
LANGFUSE_SAMPLING_RATE=1.0          # Langfuse 采样率
LANGFUSE_MASK_PII=true              # 是否对可观测数据中的敏感信息脱敏
LANGFUSE_REQUEST_TIMEOUT=30         # Langfuse 请求超时时间，单位秒
LANGFUSE_MAX_RETRIES=3              # Langfuse 请求最大重试次数
LANGFUSE_RETRY_DELAY=1.0            # Langfuse 请求重试间隔，单位秒
